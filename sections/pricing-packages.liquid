{% liquid
  assign pricing_type = section.settings.pricing_type
  assign phone_href = settings.business_phone | remove: '-' | remove: ' '
%}
<section class="section pricing-section {% if section.settings.use_light_background %}section-light{% endif %}">
  <div class="section-inner">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.intro }}</p>
    </div>
    {% case pricing_type %}
      {% when 'tshirts' %}
        <div class="pricing-grid">
          <article class="pricing-card"><h3>Value T-Shirts</h3><p>Budget-friendly event shirts, school shirts, giveaways and large runs.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>50</td><td>$299</td></tr><tr><td>100</td><td>$399</td></tr><tr><td>500</td><td>$1,899</td></tr><tr><td>1000</td><td>$3,699</td></tr></tbody></table></article>
          <article class="pricing-card pricing-featured"><span class="pricing-badge">Recommended</span><h3>Softstyle T-Shirts</h3><p>The default package for most customers who want comfort and value.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>50</td><td>$349</td></tr><tr><td>100</td><td>$449</td></tr><tr><td>500</td><td>$2,199</td></tr><tr><td>1000</td><td>$4,299</td></tr></tbody></table></article>
          <article class="pricing-card"><h3>Premium T-Shirts</h3><p>Retail-quality apparel for brands, staff shirts and premium events.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>50</td><td>$399</td></tr><tr><td>100</td><td>$549</td></tr><tr><td>500</td><td>$2,599</td></tr><tr><td>1000</td><td>$4,999</td></tr></tbody></table></article>
        </div>
      {% when 'hoodies' %}
        <div class="pricing-grid">
          <article class="pricing-card"><h3>Value Hoodies</h3><p>Great for schools, churches, teams and crew apparel.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>50</td><td>$650</td></tr><tr><td>100</td><td>$1,199</td></tr><tr><td>500</td><td>$5,950</td></tr><tr><td>1000</td><td>$11,500</td></tr></tbody></table></article>
          <article class="pricing-card pricing-featured"><span class="pricing-badge">Popular</span><h3>Mid-Range Hoodies</h3><p>A balanced option for spirit wear, teams and staff apparel.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>50</td><td>$799</td></tr><tr><td>100</td><td>$1,499</td></tr><tr><td>500</td><td>$7,250</td></tr><tr><td>1000</td><td>$13,999</td></tr></tbody></table></article>
          <article class="pricing-card"><h3>Premium Hoodies</h3><p>Premium feel for retail-style merch, staff gifts and higher-end events.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>50</td><td>$949</td></tr><tr><td>100</td><td>$1,799</td></tr><tr><td>500</td><td>$8,999</td></tr><tr><td>1000</td><td>$16,999</td></tr></tbody></table></article>
        </div>
      {% when 'polos' %}
        <div class="pricing-grid">
          <article class="pricing-card pricing-featured"><span class="pricing-badge">Business starter</span><h3>Value Embroidered Polos</h3><p>Professional left-chest polos for businesses and organizations.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>10</td><td>$179</td></tr><tr><td>25</td><td>$375</td></tr><tr><td>50</td><td>$749</td></tr></tbody></table></article>
          <article class="pricing-card"><h3>Mid-Range Embroidered Polos</h3><p>Polished apparel for medical offices, churches, restaurants and teams.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>10</td><td>$219</td></tr><tr><td>25</td><td>$425</td></tr><tr><td>50</td><td>$899</td></tr></tbody></table></article>
          <article class="pricing-card"><h3>Premium Embroidered Polos</h3><p>Higher-end polos for staff uniforms, sales teams and client-facing apparel.</p><table><thead><tr><th>Quantity</th><th>Starting Price</th></tr></thead><tbody><tr><td>10</td><td>$269</td></tr><tr><td>25</td><td>$525</td></tr><tr><td>50</td><td>$1,099</td></tr></tbody></table></article>
        </div>
      {% when 'dtf' %}
        <div class="pricing-grid pricing-grid-wide">
          <article class="pricing-card pricing-featured"><span class="pricing-badge">Starts at $2.50</span><h3>DTF Transfer Sizes</h3><p>Upload artwork for review. Gang sheets, oversized transfers and complex work need a custom quote.</p><table><thead><tr><th>Transfer Type</th><th>Max Size</th><th>Starting Price</th></tr></thead><tbody><tr><td>Pocket Transfer</td><td>up to 4 inches</td><td>$2.50</td></tr><tr><td>Left Chest Transfer</td><td>up to 5 inches</td><td>$3.50</td></tr><tr><td>Letter Size Transfer</td><td>8.5 x 11 inches</td><td>$5.99</td></tr><tr><td>Large Front Transfer</td><td>11 x 11 inches</td><td>$7.99</td></tr><tr><td>Oversize Transfer</td><td>11 x 16 inches</td><td>$9.99</td></tr><tr><td>Gang Sheet</td><td>Custom</td><td>Request Quote</td></tr></tbody></table></article>
          <article class="pricing-card"><h3>Bulk DTF Discounts</h3><p>Bulk transfer pricing helps small brands, events and repeat designs save more as quantity increases.</p><table><thead><tr><th>Quantity</th><th>Discount / Pricing Note</th></tr></thead><tbody><tr><td>10+</td><td>10% off</td></tr><tr><td>25+</td><td>15% off</td></tr><tr><td>50+</td><td>20% off</td></tr><tr><td>100+</td><td>Request custom quote</td></tr></tbody></table></article>
        </div>
      {% when 'promo' %}
        <div class="pricing-grid pricing-grid-wide">
          <article class="pricing-card pricing-featured"><span class="pricing-badge">Starts at $0.39</span><h3>Promotional Product Examples</h3><p>Final pricing depends on product, quantity, decoration method, setup and turnaround time.</p><table><thead><tr><th>Category</th><th>Starting Price</th></tr></thead><tbody><tr><td>Trade Show Giveaways</td><td>$0.39 each</td></tr><tr><td>Pens</td><td>$0.49 each</td></tr><tr><td>Can Coolers</td><td>$0.99 each</td></tr><tr><td>Keychains</td><td>$1.49 each</td></tr><tr><td>Office Products</td><td>$1.99 each</td></tr><tr><td>Drinkware</td><td>$2.99 each</td></tr><tr><td>Tote Bags</td><td>$3.99 each</td></tr></tbody></table></article>
          <article class="pricing-card"><h3>Quote-Based Promo Items</h3><p>Employee gifts, awards and premium branded merchandise need product selection and quantity review.</p><table><thead><tr><th>Category</th><th>Pricing</th></tr></thead><tbody><tr><td>Employee Gifts</td><td>Request Quote</td></tr><tr><td>Awards</td><td>Request Quote</td></tr><tr><td>Premium Branded Merchandise</td><td>Request Quote</td></tr></tbody></table></article>
        </div>
      {% when 'featured' %}
        <div class="pricing-grid">
          <article class="pricing-card"><h3>100 Softstyle Shirts</h3><p>Recommended custom t-shirt package.</p><strong class="price-callout">Starting at $449</strong></article>
          <article class="pricing-card"><h3>25 Embroidered Polos</h3><p>Great for companies and organizations.</p><strong class="price-callout">Starting at $375</strong></article>
          <article class="pricing-card"><h3>50 Hoodies</h3><p>Strong option for spirit wear and crews.</p><strong class="price-callout">Starting at $650</strong></article>
          <article class="pricing-card"><h3>Custom DTF Transfers</h3><p>For detailed artwork and small batches.</p><strong class="price-callout">Starting at $2.50</strong></article>
          <article class="pricing-card"><h3>Promotional Products</h3><p>Giveaways, bags, drinkware and more.</p><strong class="price-callout">Starting at $0.39</strong></article>
        </div>
    {% endcase %}
    <p class="pricing-disclaimer">Prices shown are starting prices and may vary based on garment brand, quantity, artwork, print locations, decoration method, turnaround time and availability. Final pricing is confirmed after artwork and order details are reviewed.</p>
    <div class="section-actions pricing-actions">
      <a class="button button-dark" href="tel:{{ phone_href }}">Call {{ settings.business_phone }}</a>
      <a class="button" href="/pages/request-a-quote">Request A Quote</a>
      <a class="button button-secondary" href="/pages/upload-artwork">Upload Artwork</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Pricing packages",
  "settings": [
    { "type": "select", "id": "pricing_type", "label": "Pricing type", "default": "featured", "options": [
      { "value": "featured", "label": "Homepage featured" },
      { "value": "tshirts", "label": "Custom T-Shirts" },
      { "value": "hoodies", "label": "Hoodies" },
      { "value": "polos", "label": "Embroidered Polos" },
      { "value": "dtf", "label": "DTF Transfers" },
      { "value": "promo", "label": "Promotional Products" }
    ] },
    { "type": "checkbox", "id": "use_light_background", "label": "Use light background", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pricing examples" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Starting-price packages built for fast quote requests." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Use these pricing examples to plan your order, then call, request a quote or upload artwork for final review." }
  ]
}
{% endschema %}
