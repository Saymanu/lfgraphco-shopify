{% liquid
  assign phone_href = settings.business_phone | remove: '-' | remove: ' '
%}
<section class="section mockup-offer">
  <div class="section-inner mockup-card">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.intro }}</p>
      <ul class="conversion-checklist">
        {% assign points = section.settings.bullets | split: "," %}
        {% for point in points %}
          {% if point != blank %}<li>{{ point | strip }}</li>{% endif %}
        {% endfor %}
      </ul>
    </div>
    <div class="mockup-actions">
      <a class="button" href="/pages/request-a-quote">Request A Quote</a>
      <a class="button button-secondary" href="/pages/upload-artwork">Upload Artwork</a>
      <a class="phone" href="tel:{{ phone_href }}">Call {{ settings.business_phone }}</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Free mockup offer",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Free mockup offer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See the idea before you approve the order." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Request a quote and L F Graphco can review your logo, garment choice and placement so you know what the finished apparel is expected to look like before production starts." },
    { "type": "textarea", "id": "bullets", "label": "Bullet list", "default": "Send logos or artwork notes,Choose shirts polos hoodies hats or promo items,Review placement and quantity before final pricing" }
  ]
}
{% endschema %}
