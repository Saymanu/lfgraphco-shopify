<section class="section">
  <div class="section-inner content-grid">
    <div>
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'eager', alt: product.title }}
      {% else %}
        <div class="card product-image-fallback"><p class="eyebrow">Custom order product</p><p>Upload final product photography in Shopify when this item is ready for public sale. For custom orders, request a quote and share artwork for review.</p><a class="button button-secondary" href="/pages/upload-artwork">Upload Artwork</a></div>
      {% endif %}
    </div>
    <div>
      <p class="eyebrow">Custom apparel product</p>
      <h1>{{ product.title }}</h1>
      {% if product.description != blank %}
        <div>{{ product.description }}</div>
      {% else %}
        <p>Request pricing for this custom apparel or promotional product. Final details depend on quantity, artwork, decoration method and turnaround time.</p>
      {% endif %}
      {% form 'product', product %}
        <div class="field">
          <label for="ProductSelect">Options</label>
          <select id="ProductSelect" name="id">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>{{ variant.title }} - {{ variant.price | money }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="field"><label for="Quantity">Quantity</label><input id="Quantity" type="number" name="quantity" value="1" min="1"></div>
        <button class="button" type="submit">Add to Cart</button>
        <a class="button button-secondary" href="/pages/request-a-quote">Request Bulk Quote</a>
      {% endform %}
    </div>
  </div>
</section>
{% schema %}
{ "name": "Main product", "settings": [] }
{% endschema %}
