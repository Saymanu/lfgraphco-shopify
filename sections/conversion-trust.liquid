<section class="section conversion-trust {% if section.settings.use_light_background %}section-light{% endif %}">
  <div class="section-inner">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.intro }}</p>
    </div>
    <div class="grid trust-service-grid">
      <article class="card">
        <strong>Screen Printing</strong>
        <h3>Built for bulk apparel and event deadlines.</h3>
        <p>Use screen printing for spirit shirts, staff apparel, sponsor shirts, camps, construction crews and high-volume custom t-shirt orders.</p>
      </article>
      <article class="card">
        <strong>Embroidery</strong>
        <h3>Clean professional apparel for teams and businesses.</h3>
        <p>Polos, hats, jackets and uniforms get a polished left-chest or cap finish that works well for customer-facing staff.</p>
      </article>
      <article class="card">
        <strong>DTF Printing</strong>
        <h3>Flexible full-color decoration for detailed artwork.</h3>
        <p>DTF is a strong fit for smaller runs, detailed logos, sponsor-heavy graphics and colorful designs that need a fast quote path.</p>
      </article>
      <article class="card">
        <strong>Promotional Products</strong>
        <h3>Branded items that support events and campaigns.</h3>
        <p>Add pens, giveaways, drinkware, bags, employee gifts and other branded products to support apparel programs and local promotions.</p>
      </article>
    </div>
    <div class="section-actions">
      <a class="button" href="/pages/request-a-quote">Request A Quote</a>
      <a class="button button-secondary" href="/pages/upload-artwork">Upload Artwork</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Conversion trust",
  "settings": [
    { "type": "checkbox", "id": "use_light_background", "label": "Use light background", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why L F Graphco" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One local partner for apparel, printing and branded products." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Customers can start with a rough idea, a logo file or a deadline. L F Graphco helps turn that into quote-ready details." }
  ]
}
{% endschema %}
