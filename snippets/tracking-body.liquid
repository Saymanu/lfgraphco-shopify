{% if settings.gtm_container_id != blank %}
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id={{ settings.gtm_container_id }}" height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
{% endif %}
{% if settings.meta_pixel_id != blank %}
  <noscript>
    <img height="1" width="1" style="display:none" alt="" src="https://www.facebook.com/tr?id={{ settings.meta_pixel_id }}&ev=PageView&noscript=1">
  </noscript>
{% endif %}
