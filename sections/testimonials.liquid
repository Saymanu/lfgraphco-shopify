<section class="section testimonials {% if section.settings.use_light_background %}section-light{% endif %}">
  <div class="section-inner">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.intro }}</p>
    </div>
    <div class="grid">
      <article class="card">
        <strong>Schools and booster clubs</strong>
        <p>Clear quote guidance, spirit wear options and artwork support help groups plan apparel around real deadlines.</p>
      </article>
      <article class="card">
        <strong>Businesses and crews</strong>
        <p>Uniform programs can include screen printed work shirts, embroidered polos, hats, safety apparel and promotional items.</p>
      </article>
      <article class="card">
        <strong>Events and families</strong>
        <p>From reunions to birthdays and bridal parties, L F Graphco supports both custom group orders and ready-to-order designs.</p>
      </article>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Reviews and testimonials",
  "settings": [
    { "type": "checkbox", "id": "use_light_background", "label": "Use light background", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews and trust" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for groups that need apparel done right." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Use this section for real customer reviews after launch. Until then, it highlights the customer groups L F Graphco serves every day." }
  ]
}
{% endschema %}
