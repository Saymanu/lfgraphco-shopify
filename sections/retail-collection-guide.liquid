<section class="section retail-guide {% if section.settings.use_light_background %}section-light{% endif %}">
  <div class="section-inner content-grid">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.intro }}</p>
      <ul class="feature-list">
        <li>Select Design</li>
        <li>Select Size</li>
        <li>Select Shirt Color</li>
        <li>Optional Personalization</li>
        <li>Add to Cart</li>
        <li>Checkout</li>
      </ul>
    </div>
    <aside class="form-panel">
      <h3>Need this for a group?</h3>
      <p>Retail designs are made for quick checkout. Schools, teams, churches, companies and events should request a bulk quote for best pricing and planning.</p>
      <a class="button" href="/pages/request-a-quote">Request A Quote</a>
      <a class="button button-secondary" href="/pages/upload-artwork">Upload Artwork</a>
    </aside>
  </div>
</section>
{% schema %}
{
  "name": "Retail collection guide",
  "settings": [
    { "type": "checkbox", "id": "use_light_background", "label": "Use light background", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready-to-order apparel" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose a design, personalize if available and check out." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "These retail collections are for simple shirt designs that can be purchased without a quote. Select product options in Shopify, add personalization when offered and complete checkout." }
  ]
}
{% endschema %}
