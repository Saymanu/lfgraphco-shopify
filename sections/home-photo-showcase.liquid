<section class="section section-light photo-showcase">
  <div class="section-inner">
    <div class="section-header">
      <p class="eyebrow">Inside the shop</p>
      <h2>Production photos from actual L F Graphco work.</h2>
      <p>These uploaded shop photos show printed shirts in production, embroidery equipment, finished customer apparel and real workspace activity.</p>
    </div>
    <div class="photo-feature-grid">
      <figure class="photo-feature">
        <img src="https://raw.githubusercontent.com/Saymanu/lfgraphco-shopify/main/brand-assets/photos/IMG_5969.HEIC" alt="Multi-head embroidery machines in the L F Graphco shop" width="900" height="1200" loading="lazy">
        <figcaption>Embroidery equipment for hats, pullovers, polos and branded apparel.</figcaption>
      </figure>
      <figure class="photo-feature">
        <img src="https://raw.githubusercontent.com/Saymanu/lfgraphco-shopify/main/brand-assets/photos/IMG_2085.jpg" alt="Finished Impact Dallas wellness symposium shirts with sponsor logos" width="900" height="1200" loading="lazy">
        <figcaption>Finished community event shirts with sponsor logos and full-color detail.</figcaption>
      </figure>
      <figure class="photo-feature">
        <img src="https://raw.githubusercontent.com/Saymanu/lfgraphco-shopify/main/brand-assets/photos/IMG_1567.HEIC" alt="Boxes and apparel staged outside the L F Graphco workspace" width="900" height="1200" loading="lazy">
        <figcaption>Orders, blanks and supplies staged for real production flow.</figcaption>
      </figure>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Home photo showcase", "settings": [] }
{% endschema %}
